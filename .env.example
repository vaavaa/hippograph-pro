# Mehen Graph — Environment Configuration
# Copy this file to .env and fill in your values
# Never commit .env to git

# Required: API authentication key
# Generate one: python3 -c "import secrets; print('mehen_' + secrets.token_urlsafe(32))"
NEURAL_API_KEY=your-api-key-here

# Database path (SQLite)
DB_PATH=/app/data/memory.db

# Embedding model (downloads on first run, ~1.5GB)
EMBEDDING_MODEL=BAAI/bge-m3

# Reranker
RERANK_ENABLED=true
RERANK_MODEL=BAAI/bge-reranker-v2-m3
RERANK_WEIGHT=0.5
RERANK_TOP_N=20

# ANN index for fast search
USE_ANN_INDEX=true

# Retrieval weights (alpha=semantic, gamma=BM25)
BLEND_ALPHA=0.7
BLEND_GAMMA=0.15

# Spreading activation
ACTIVATION_ITERATIONS=3
ACTIVATION_DECAY=0.7
INHIBITION_STRENGTH=0.05

# Late chunking (overlap chunking for long notes)
LATE_CHUNKING_ENABLED=true
LC_MODE=parent
LC_MIN_NOTE_CHARS=100

# Keyword anchors (inline, at ingestion time)
KEYWORD_ANCHOR_ENABLED=true

# Server port
FLASK_PORT=5000