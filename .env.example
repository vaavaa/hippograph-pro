# HippoGraph Pro — Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to git!

# Required: API authentication key
# Generate one: python3 -c "import secrets; print('mehen_' + secrets.token_urlsafe(32))"
NEURAL_API_KEY=your-api-key-here

# Database path (SQLite)
DB_PATH=/app/data/memory.db

# ═══════════════════════════════════════════════════════════════
# Embedding Model
# ═══════════════════════════════════════════════════════════════
# ⚠️  CHANGING MODEL REQUIRES FULL RE-INDEX of all notes!
#     Run: python3 src/reindex_embeddings.py
#
# Recommended models (lightest to heaviest):
#
# sentence-transformers/all-MiniLM-L6-v2
#   Dims: 384 | RAM: ~80MB  | Speed: fastest  | Languages: English only
#   Best for: English-only, minimal hardware (4GB RAM)
#
# sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
#   Dims: 384 | RAM: ~120MB | Speed: fast     | Languages: 50+
#   Best for: Multilingual on modest hardware (8GB RAM)
#
# BAAI/bge-m3                                                [PRODUCTION DEFAULT]
#   Dims: 1024 | RAM: ~2.2GB | Speed: moderate | Languages: 100+
#   Best for: Maximum quality + multilingual (16GB+ RAM recommended)
#
# intfloat/multilingual-e5-large
#   Dims: 1024 | RAM: ~2.2GB | Speed: moderate | Languages: 100+
#   Best for: Alternative to bge-m3 with strong multilingual performance
#
EMBEDDING_MODEL=BAAI/bge-m3

# ═══════════════════════════════════════════════════════════════
# Reranker (improves precision, adds ~100ms latency)
# ═══════════════════════════════════════════════════════════════
RERANK_ENABLED=true
RERANK_MODEL=BAAI/bge-reranker-v2-m3
RERANK_WEIGHT=0.5
RERANK_TOP_N=20

# ═══════════════════════════════════════════════════════════════
# Retrieval
# ═══════════════════════════════════════════════════════════════
# ANN index for fast similarity search
USE_ANN_INDEX=true

# Blend scoring: final = α×semantic + β×spreading + γ×BM25 + δ×temporal
# (β = 1-α-γ-δ, spreading gets the remainder)
BLEND_ALPHA=0.7    # semantic similarity weight
BLEND_GAMMA=0.15   # BM25 keyword weight (0 = disabled)
# BLEND_DELTA=0.1  # temporal weight (0 = disabled, auto-enabled for temporal queries)

# Fusion method: 'blend' (weighted sum) or 'rrf' (Reciprocal Rank Fusion)
# RRF eliminates score scale mismatch, no weight tuning needed
# FUSION_METHOD=blend

# ═══════════════════════════════════════════════════════════════
# Spreading Activation
# ═══════════════════════════════════════════════════════════════
ACTIVATION_ITERATIONS=3
ACTIVATION_DECAY=0.7
INHIBITION_STRENGTH=0.05

# ═══════════════════════════════════════════════════════════════
# Late Chunking (overlap chunking for long notes)
# ═══════════════════════════════════════════════════════════════
LATE_CHUNKING_ENABLED=true
LC_MODE=parent
LC_MIN_NOTE_CHARS=100

# Keyword anchors (inline, at ingestion time)
KEYWORD_ANCHOR_ENABLED=true

# Server port
FLASK_PORT=5000